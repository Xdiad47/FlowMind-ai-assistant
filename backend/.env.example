# Server
PORT=8000
ENVIRONMENT=development
ALLOWED_ORIGINS=http://localhost:3000

# Frontend URL — used for post-OAuth redirects (e.g. Microsoft callback).
# Set to your production frontend domain when deploying.
# e.g. FRONTEND_URL=https://flowmind-frontend-alpha.vercel.app
FRONTEND_URL=http://localhost:3000

# Firebase Admin SDK
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=

# Encryption
MASTER_ENCRYPTION_KEY=your-32-byte-hex-key-here

# FlowMind Hosted AI (for Pro Hosted tier users)
PLATFORM_GROQ_API_KEY=
PLATFORM_GEMINI_API_KEY=

# Google OAuth (for server-side token refresh)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
